#!/usr/bin/env bash
# cc-sessions: fzf TUIでセッション一覧→resume (SQLite版)
# 使用法:
#   cc-sessions          現在のcwdに紐づくセッション一覧
#   cc-sessions --all    全cwdのセッション
#   cc-sessions --cwd P  指定パスのセッション

set -u

DB="$HOME/.claude/sessions/index.db"

# ID サニタイズ共通関数: UUID フォーマット ([0-9a-fA-F-] のみ) 以外は弾く (SQLi 防御)
_validate_id() {
  case "$1" in
    ''|*[!0-9a-fA-F-]*) echo "invalid id: $1" >&2; return 1 ;;
  esac
  return 0
}

# 内部サブコマンド: fzf preview 用（外部から呼ばれる）
if [ "${1:-}" = "_preview" ]; then
  ID="${2:-}"
  [ -z "$ID" ] && exit 0
  _validate_id "$ID" || exit 1
  sqlite3 -json "$DB" "SELECT * FROM sessions WHERE id = '$ID';" \
  | jq -r '.[0] |
      "ID:       \(.id)\n" +
      "Title:    \(.title // "-")\n" +
      "Ended:    \(.ended_at // "-")\n" +
      "Turns:    \(.turns // 0)\n" +
      "Duration: \((.duration_ms // 0) / 1000 | floor) sec\n" +
      "Reason:   \(.reason // "-")\n" +
      "CWD:      \(.cwd // "-")\n" +
      "\n--- Summary ---\n\(.summary // "(none)")\n" +
      "\n--- Transcript ---\n\(.transcript // "-")"'
  exit 0
fi

# 内部サブコマンド: title 編集 (1行入力)
if [ "${1:-}" = "_edit_title" ]; then
  ID="${2:-}"
  _validate_id "$ID" || exit 1
  CURRENT=$(sqlite3 -json "$DB" "SELECT title FROM sessions WHERE id = '$ID';" | jq -r '.[0].title // ""')
  printf 'current title: %s\n' "$CURRENT" >&2
  printf 'new title (empty=cancel): ' >&2
  IFS= read -r NEW < /dev/tty || exit 0
  [ -z "$NEW" ] && { echo "canceled" >&2; exit 0; }
  sqlite3 "$DB" <<SQL
.parameter set :id    $(printf '%s' "$ID"  | jq -Rs .)
.parameter set :title $(printf '%s' "$NEW" | jq -Rs .)
UPDATE sessions SET title = :title WHERE id = :id;
SQL
  echo "updated" >&2
  exit 0
fi

# 内部サブコマンド: summary 編集 ($EDITOR 起動、複数行)
if [ "${1:-}" = "_edit_summary" ]; then
  ID="${2:-}"
  _validate_id "$ID" || exit 1
  CURRENT=$(sqlite3 -json "$DB" "SELECT summary FROM sessions WHERE id = '$ID';" | jq -r '.[0].summary // ""')
  TMP=$(mktemp -t cc-sessions-summary.XXXXXX) || exit 1
  trap 'rm -f "$TMP"' EXIT
  printf '%s' "$CURRENT" > "$TMP"
  "${EDITOR:-vi}" "$TMP" < /dev/tty > /dev/tty 2>&1 || { echo "editor failed" >&2; exit 1; }
  NEW=$(cat "$TMP")
  if [ "$NEW" = "$CURRENT" ]; then
    echo "no change" >&2
    exit 0
  fi
  sqlite3 "$DB" <<SQL
.parameter set :id      $(printf '%s' "$ID"  | jq -Rs .)
.parameter set :summary $(printf '%s' "$NEW" | jq -Rs .)
UPDATE sessions SET summary = :summary WHERE id = :id;
SQL
  echo "updated" >&2
  exit 0
fi

# 内部サブコマンド: fzf reload 用 一覧出力
if [ "${1:-}" = "_list" ]; then
  shift
  _LIST_MODE="${1:-cwd}"
  _LIST_CWD="${2:-$PWD}"
  if [ "$_LIST_MODE" = "all" ]; then
    _WHERE=""
    _PARAM_CWD=""
  else
    _WHERE="WHERE cwd = :cwd"
    _PARAM_CWD=".parameter set :cwd $(printf '%s' "$_LIST_CWD" | jq -Rs .)"
  fi
  _LINES=$(sqlite3 -separator $'\t' "$DB" <<SQL
$_PARAM_CWD
.parameter set :home $(printf '%s' "$HOME" | jq -Rs .)

SELECT
  id,
  COALESCE(strftime('%Y-%m-%d %H:%M', ended_at, 'localtime'), '-'),
  COALESCE(turns, 0),
  CASE
    WHEN cwd IS NULL OR cwd = '' THEN '-'
    WHEN substr(cwd, 1, length(:home)) = :home THEN '~' || substr(cwd, length(:home) + 1)
    ELSE cwd
  END,
  substr(REPLACE(COALESCE(NULLIF(title, ''), summary, ''), char(9), ' '), 1, 120),
  COALESCE(cwd, '-')
FROM sessions
$_WHERE
ORDER BY ended_at DESC;
SQL
  )
  echo "$_LINES" | awk -F'\t' 'NF>=6 {
    disp = sprintf("%-16s  %4s turns  %-30s  %s", $2, $3, $4, $5)
    printf "%s\t%s\t%s\n", $1, disp, $6
  }'
  exit 0
fi

[ ! -s "$DB" ] && { echo "no sessions recorded yet: $DB"; exit 1; }

MODE="cwd"
TARGET_CWD="$PWD"
case "${1:-}" in
  --all) MODE="all" ;;
  --cwd) MODE="cwd"; TARGET_CWD="${2:-$PWD}" ;;
  -h|--help) echo "usage: cc-sessions [--all|--cwd PATH]"; exit 0 ;;
esac

# 自身のフルパス（preview/edit/reload用に保存。symlink解決後）
SELF="$(command -v "$0" 2>/dev/null || echo "$0")"
case "$SELF" in /*) ;; *) SELF="$PWD/$SELF" ;; esac

# 一覧取得 (_list サブコマンド経由 → reload と共通化)
DISPLAY=$("$SELF" _list "$MODE" "$TARGET_CWD")

if [ -z "$DISPLAY" ]; then
  if [ "$MODE" = "cwd" ]; then
    echo "no sessions for cwd=$TARGET_CWD (try --all)"
  else
    echo "no sessions found"
  fi
  exit 1
fi

# preview/edit/reload: 自身をサブコマンド再帰呼出（quoting地獄回避）
PREVIEW="$SELF _preview {1}"
EDIT_TITLE="$SELF _edit_title {1}"
EDIT_SUMMARY="$SELF _edit_summary {1}"
RELOAD="$SELF _list $MODE $(printf '%q' "$TARGET_CWD")"

SELECTED=$(echo "$DISPLAY" | fzf \
  --delimiter='\t' \
  --with-nth=2 \
  --preview="$PREVIEW" \
  --preview-window='right:55%:wrap' \
  --bind="ctrl-e:execute($EDIT_TITLE)+reload($RELOAD)+refresh-preview" \
  --bind="ctrl-s:execute($EDIT_SUMMARY)+reload($RELOAD)+refresh-preview" \
  --header='enter=resume / ctrl-e=edit title / ctrl-s=edit summary / ctrl-c=quit / mode='"$MODE"' / cols: ended | turns | cwd | title' \
  --ansi)

[ -z "$SELECTED" ] && exit 0

ID=$(echo "$SELECTED" | cut -f1)
SCWD=$(echo "$SELECTED" | cut -f3)

# cwd 切替してresume
if [ -n "$SCWD" ] && [ -d "$SCWD" ] && [ "$SCWD" != "$PWD" ]; then
  echo "cd $SCWD && claude --resume $ID"
  cd "$SCWD" && exec claude --resume "$ID"
else
  exec claude --resume "$ID"
fi
